{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",
    "isolatedModules": true,
    "noEmit": true,

    "skipLibCheck": true,
    "useDefineForClassFields": true,

    "strict": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}